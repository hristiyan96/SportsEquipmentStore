@model IEnumerable<SportsEquipmentStore.Models.Review>

<h1>Reviews</h1>
<a asp-action="Create" class="btn btn-primary">Add New Review</a>

<table class="table">
    <thead>
        <tr>
            <th>Equipment</th>
            <th>Customer</th>
            <th>Rating</th>
            <th>Comment</th>
            <th>Review Date</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Equipment.Name</td>
                <td>@item.Customer.FirstName @item.Customer.LastName</td>
                <td>@item.Rating</td>
                <td>@item.Comment</td>
                <td>@item.ReviewDate.ToShortDateString()</td>
                <td>
                    <a asp-action="Edit" asp-route-id="@item.Id" class="btn btn-secondary btn-sm">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-danger btn-sm">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
<footer class="bg-dark text-white text-center py-3">
    <p>&copy; @DateTime.Now.Year - Sports Equipment Store</p>
    <div class="d-flex justify-content-center">
        <img src="/images/logo1.png" alt="Brand 1" class="mx-2" style="height: 40px;">
        <img src="/images/logo2.png" alt="Brand 2" class="mx-2" style="height: 40px;">
        <img src="/images/logo3.png" alt="Brand 3" class="mx-2" style="height: 40px;">
    </div>
</footer>

